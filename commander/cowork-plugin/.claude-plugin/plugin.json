{
  "name": "commander",
  "version": "4.0.0-beta.1",
  "description": "CC Commander — Guided AI PM to Master Claude Code Instantly. 1 MCP server. 456+ skills. Every AI IDE. Free in beta. Works in Claude Code, Cursor, Windsurf, Cline, Continue, Codex, and more.",
  "author": {
    "name": "Kevin Zicherman",
    "url": "https://kevinz.ai"
  },
  "homepage": "https://cc-commander.com",
  "repository": "https://github.com/KevinZai/commander",
  "license": "MIT",
  "keywords": [
    "project-manager",
    "skills",
    "orchestration",
    "linear",
    "fleet",
    "knowledge",
    "night-mode",
    "desktop",
    "web-search",
    "tavily",
    "context7",
    "mcp",
    "mcp-server",
    "hosted",
    "beta",
    "cursor",
    "windsurf"
  ],
  "skills": "./skills/",
  "agents": "./agents/",
  "tiers": {
    "free": [
      "commander",
      "build",
      "linear-board",
      "research",
      "content",
      "session",
      "settings",
      "domains",
      "night-mode",
      "standup",
      "code-review",
      "deploy-check",
      "fleet",
      "ccc-data",
      "ccc-design",
      "ccc-devops",
      "ccc-makeover",
      "ccc-marketing",
      "ccc-mobile",
      "ccc-research",
      "ccc-saas",
      "ccc-security",
      "ccc-seo",
      "ccc-testing"
    ],
    "pro": [
      "infra",
      "knowledge"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/session-start.js",
        "timeout": 10000
      }
    ],
    "UserPromptSubmit": [
      {
        "type": "command",
        "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/intent-classifier.js",
        "timeout": 5000
      },
      {
        "type": "command",
        "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/user-prompt-submit.js",
        "timeout": 5000
      }
    ],
    "SubagentStop": [
      {
        "type": "command",
        "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/subagent-stop.js",
        "timeout": 5000
      }
    ],
    "PreToolUse": [
      {
        "type": "command",
        "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/cost-tracker.js",
        "timeout": 3000
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/knowledge-capture.js",
        "timeout": 5000
      }
    ],
    "PreCompact": [
      {
        "type": "command",
        "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/pre-compact.js",
        "timeout": 5000
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/session-save.js",
        "timeout": 10000
      },
      {
        "type": "command",
        "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/session-end.js",
        "timeout": 10000
      }
    ],
    "Notification": [
      {
        "type": "command",
        "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/fleet-notify.js",
        "timeout": 5000
      }
    ],
    "PermissionDenied": [
      {
        "type": "command",
        "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/permission-denied.js",
        "timeout": 5000
      }
    ]
  }
}
