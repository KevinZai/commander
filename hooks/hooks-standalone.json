{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_description": "Standalone hooks for CC Commander. Use this if you do NOT have ECC installed. All 15 kit-native hooks organized by lifecycle.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/careful-guard.js"
          }
        ],
        "description": "Block destructive commands (rm -rf, DROP TABLE, force push, etc.)"
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/pre-commit-verify.js",
            "timeout": 15
          }
        ],
        "description": "Run TypeScript check before git commit — blocks on tsc errors"
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/confidence-gate.js"
          }
        ],
        "description": "Warn on multi-file bash operations (sed -i on globs, find -exec, etc.)"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/auto-notify.js"
          }
        ],
        "description": "Auto-notify on significant events"
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/preuse-logger.js"
          }
        ],
        "description": "Log tool usage for analysis"
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/context-guard.js"
          }
        ],
        "description": "Track context usage — warns at ~70% and auto-saves session"
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/auto-checkpoint.js"
          }
        ],
        "description": "Auto git-stash checkpoint every 10 file edits"
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/cost-alert.js"
          }
        ],
        "description": "Cost proxy alerts at ~$0.50 (30 calls) and ~$2.00 (60 calls)"
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/auto-lessons.js"
          }
        ],
        "description": "Auto-capture errors and corrections to tasks/lessons.md"
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/rate-predictor.js"
          }
        ],
        "description": "Predict session duration based on tool call rate"
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/pre-compact.js"
          }
        ],
        "description": "Auto-save session state (cwd, git branch, modified files, active tasks) before context compaction"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/status-checkin.js"
          }
        ],
        "description": "Session end status check-in"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/session-end-verify.js"
          }
        ],
        "description": "Verify modified files and check for console.log on session end"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/session-coach.js"
          }
        ],
        "description": "Periodic coaching nudges — skill suggestions, workflow tips, checkpoint reminders"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/self-verify.js"
          }
        ],
        "description": "Check for incomplete tasks, uncommitted changes, and TODO/FIXME in modified files"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Blow.aiff"
          }
        ],
        "description": "Play sound on session completion (macOS)"
      }
    ]
  }
}
