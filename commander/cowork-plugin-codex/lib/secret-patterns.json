{
  "version": "1.0.0",
  "description": "Regex patterns for detecting secrets in tool inputs. Used by secret-leak-guard.js",
  "patterns": [
    {
      "id": "aws-access-key",
      "label": "AWS Access Key ID",
      "regex": "AKIA[0-9A-Z]{16}",
      "severity": "critical"
    },
    {
      "id": "aws-secret-key",
      "label": "AWS Secret Access Key",
      "regex": "(?i)aws.{0,20}secret.{0,20}['\"][0-9a-zA-Z/+]{40}['\"]",
      "severity": "critical"
    },
    {
      "id": "stripe-live-secret",
      "label": "Stripe Live Secret Key",
      "regex": "sk_live_[0-9a-zA-Z]{24,}",
      "severity": "critical"
    },
    {
      "id": "stripe-live-publishable",
      "label": "Stripe Live Publishable Key",
      "regex": "pk_live_[0-9a-zA-Z]{24,}",
      "severity": "high"
    },
    {
      "id": "github-pat",
      "label": "GitHub Personal Access Token",
      "regex": "ghp_[0-9a-zA-Z]{36,}",
      "severity": "critical"
    },
    {
      "id": "github-oauth",
      "label": "GitHub OAuth Token",
      "regex": "gho_[0-9a-zA-Z]{36,}",
      "severity": "critical"
    },
    {
      "id": "github-app-token",
      "label": "GitHub App Token",
      "regex": "ghs_[0-9a-zA-Z]{36,}",
      "severity": "critical"
    },
    {
      "id": "jwt-token",
      "label": "JWT Token",
      "regex": "eyJ[A-Za-z0-9_-]{10,}\\.[A-Za-z0-9_-]{10,}\\.[A-Za-z0-9_-]{10,}",
      "severity": "high"
    },
    {
      "id": "anthropic-api-key",
      "label": "Anthropic API Key",
      "regex": "sk-ant-[0-9a-zA-Z\\-]{40,}",
      "severity": "critical"
    },
    {
      "id": "openai-api-key",
      "label": "OpenAI API Key",
      "regex": "sk-[0-9a-zA-Z]{20,}T3BlbkFJ[0-9a-zA-Z]{20,}",
      "severity": "critical"
    },
    {
      "id": "openai-api-key-v2",
      "label": "OpenAI API Key (v2 format)",
      "regex": "sk-proj-[0-9a-zA-Z_\\-]{40,}",
      "severity": "critical"
    },
    {
      "id": "slack-token",
      "label": "Slack Token",
      "regex": "xox[baprs]-[0-9a-zA-Z\\-]{10,}",
      "severity": "critical"
    },
    {
      "id": "private-key-header",
      "label": "Private Key (PEM header)",
      "regex": "-----BEGIN (RSA |EC |DSA |OPENSSH )?PRIVATE KEY-----",
      "severity": "critical"
    },
    {
      "id": "sendgrid-key",
      "label": "SendGrid API Key",
      "regex": "SG\\.[0-9a-zA-Z_\\-]{22,}\\.[0-9a-zA-Z_\\-]{43,}",
      "severity": "critical"
    },
    {
      "id": "twilio-sid",
      "label": "Twilio Account SID",
      "regex": "AC[0-9a-f]{32}",
      "severity": "high"
    },
    {
      "id": "google-api-key",
      "label": "Google API Key",
      "regex": "AIza[0-9A-Za-z\\-_]{35}",
      "severity": "high"
    }
  ],
  "allowlist": [
    "AKIA_EXAMPLE",
    "sk_test_",
    "pk_test_",
    "sk-ant-example",
    "your-api-key-here",
    "REPLACE_ME",
    "INSERT_YOUR_KEY"
  ]
}
