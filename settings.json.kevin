{
  "env": {
    "ANTHROPIC_MODEL": "claude-opus-4-6",
    "NODE_OPTIONS": "--max-old-space-size=4096",
    "ANTHROPIC_MAX_THINKING_TOKENS": "131072"
  },
  "permissions": {
    "allow": [
      "Read(//dev/**)",
      "Read(//tmp/**)",
      "Bash(npm install:*)",
      "Bash(npm run:*)",
      "Bash(pnpm install:*)",
      "Bash(pnpm run:*)",
      "Bash(pnpm test:*)",
      "Bash(pnpm build:*)",
      "Bash(npx:*)",
      "Bash(npx eslint:*)",
      "Bash(npx tsx:*)",
      "Bash(npx playwright:*)",
      "Bash(node:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git status:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git stash:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(gh:*)",
      "Bash(curl:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(wc:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(ls:*)",
      "Bash(stat:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(pm2 list:*)",
      "Bash(pm2 show:*)",
      "Bash(pm2 logs:*)",
      "Bash(pm2 restart:*)",
      "Bash(linear:*)",
      "Bash(xfetch:*)",
      "Bash(x search:*)",
      "Bash(chub:*)",
      "Bash(qmd:*)",
      "Bash(discrawl:*)",
      "WebFetch(domain:*)",
      "WebSearch",
      "Skill(*)"
    ],
    "defaultMode": "acceptEdits"
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "playground@claude-plugins-official": true,
    "example-skills@anthropic-agent-skills": true,
    "productivity@knowledge-work-plugins": true,
    "sales@knowledge-work-plugins": true,
    "customer-support@knowledge-work-plugins": true,
    "product-management@knowledge-work-plugins": true,
    "marketing@knowledge-work-plugins": true,
    "legal@knowledge-work-plugins": true,
    "finance@knowledge-work-plugins": true,
    "data@knowledge-work-plugins": true,
    "enterprise-search@knowledge-work-plugins": true,
    "engineering@knowledge-work-plugins": true,
    "design@knowledge-work-plugins": true,
    "operations@knowledge-work-plugins": true,
    "human-resources@knowledge-work-plugins": true,
    "cowork-plugin-management@knowledge-work-plugins": true
  },
  "extraKnownMarketplaces": {
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    },
    "knowledge-work-plugins": {
      "source": {
        "source": "github",
        "repo": "anthropics/knowledge-work-plugins"
      }
    }
  },
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true,
  "preferredApiProvider": "firstParty",
  "mcpServers": {
    "github": {
      "command": "/Users/ai/bin/mcp-github"
    },
    "github-gn": {
      "command": "/Users/ai/bin/mcp-github-gn"
    },
    "linear": {
      "command": "/Users/ai/bin/mcp-linear"
    },
    "linear-gn": {
      "command": "/Users/ai/bin/mcp-linear-gn"
    },
    "vibe-annotations": {
      "type": "http",
      "url": "http://127.0.0.1:3846/mcp"
    },
    "shadcn-ui": {
      "command": "/Users/ai/bin/mcp-shadcn"
    }
  }
}
