      "next": "content-social"
    },
    {
      "key": "c",
      "label": "Email campaign",
      "next": "content-email"
    },
    {
      "key": "d",
      "label": "Marketing copy",
      "next": "content-marketing"
    },
    {
      "key": "e",
      "label": "Documentation",
      "next": "content-docs"
    },
    {
      "key": "f",
