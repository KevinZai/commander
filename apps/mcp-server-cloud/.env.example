# CC Commander MCP server — required env vars
# Copy to .env.local for local dev. Production secrets live in Fly.io / 1Password.
#
# ⚠️ Never commit a real .env file. .gitignore already excludes it.

# ── Required: Supabase ───────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Required: Upstash Redis (rate limiting) ─────────────────────────────────
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

# ── Required: JWT signing ────────────────────────────────────────────────────
# Must be at least 32 chars. Generate: openssl rand -hex 32
JWT_SECRET=change-me-min-32-chars-for-production

# ── Optional: PostHog analytics ──────────────────────────────────────────────
POSTHOG_API_KEY=

# ── Server ──────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development
